# Local dev uses SQLite — zero external setup.
# In production this becomes a Postgres/Neon connection string
# (change the datasource provider in prisma/schema.prisma to "postgresql").
DATABASE_URL="file:./dev.db"

# Server-side salt used to hash visitor IPs before they are ever stored.
# Generate a real random value for production.
IP_HASH_SALT="change-me-to-a-long-random-string"
