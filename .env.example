# Postgres connection string.
# For deployment, create a free database at https://neon.tech and paste its
# connection string here. Use the "Direct"/unpooled string so migrations run cleanly.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Server-side salt used to hash visitor IPs before they are ever stored.
# Generate a long random value for production.
IP_HASH_SALT="change-me-to-a-long-random-string"
